{
  "expo": {
    "name": "LohParkir",
    "slug": "lohparkir",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lohparkir",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a237e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "id.lohparkir.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "LohParkir membutuhkan akses kamera untuk scan QR Code petugas parkir.",
        "NSLocationWhenInUseUsageDescription": "LohParkir membutuhkan lokasi GPS untuk mencatat posisi saat scan dan membuat laporan.",
        "NSPhotoLibraryUsageDescription": "LohParkir membutuhkan akses foto untuk menyertakan bukti dalam laporan."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a237e"
      },
      "package": "id.lohparkir.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        { "cameraPermission": "LohParkir membutuhkan akses kamera untuk scan QR Code petugas parkir." }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "LohParkir membutuhkan lokasi untuk mencatat posisi scan dan laporan." }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1a237e",
          "sounds": ["./assets/sounds/emergency.wav"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:3001/api/v1",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
