# =============================================================
# LohParkir Backend — Environment Variables
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan server.
# JANGAN commit file .env ke repository!
# =============================================================

# ─── Environment Aplikasi ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=LohParkir API
APP_VERSION=1.0.0

# ─── Database PostgreSQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lohparkir
DB_USER=postgres
# Ganti dengan password PostgreSQL Anda
DB_PASSWORD=your_postgres_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT (JSON Web Token) ─────────────────────────────────────────────────────
# Minimal 32 karakter — gunakan string acak yang aman
# Contoh generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_32plus_char_secret_key_for_jwt
JWT_REFRESH_SECRET=change_this_to_another_random_32plus_char_secret_for_refresh
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Firebase Cloud Messaging (FCM) ───────────────────────────────────────────
# Untuk development, kosongkan variabel ini (sistem akan berjalan dalam mode mock)
# Untuk production, isi dengan kredensial dari Firebase Console
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Payment Gateway (QRIS) ───────────────────────────────────────────────────
# PAYMENT_MODE=mock → gunakan mock payment (default untuk development)
# PAYMENT_MODE=live → integrasi ke payment gateway nyata
PAYMENT_MODE=mock
PAYMENT_GATEWAY_URL=https://api.payment-gateway.example.com
PAYMENT_GATEWAY_KEY=your_payment_gateway_api_key
PAYMENT_MERCHANT_ID=your_merchant_id

# ─── Upload File ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ─── Enkripsi & Keamanan ──────────────────────────────────────────────────────
# ENCRYPTION_KEY: minimal 32 karakter — untuk enkripsi AES-256 data sensitif
ENCRYPTION_KEY=change_this_to_a_random_32plus_char_encryption_key_aes
BCRYPT_ROUNDS=12

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# 100 request per menit per IP (60000 ms = 1 menit)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── CORS — Allowed Origins ───────────────────────────────────────────────────
# Pisahkan dengan koma jika ada beberapa origin
# Production: ganti dengan domain admin dashboard yang sebenarnya
ALLOWED_ORIGINS=http://localhost:3000
